# ── Client selection ────────────────────────────────────────────────────────
# "anthropic" = call Anthropic API directly (local dev)
# "openai"    = call OpenAI API directly with your OPENAI_API_KEY
# "gateway"   = route through your enterprise AI gateway (required at work)
AGENT_CLIENT_TYPE=anthropic

# ── Option A: Direct Anthropic (local dev) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Option B: OpenAI (if you have an OpenAI API key) ─────────────────────────
# AGENT_CLIENT_TYPE=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o        # gpt-4o recommended — strong tool-use support

# ── Option C: Enterprise AI Gateway ──────────────────────────────────────────
# This mirrors the working pattern:
#   gateway_url = f"https://gateway.ai.yourcompany.com/chat/{model}"
#   client = OpenAI(api_key=key, base_url=gateway_url)
#   client.chat.completions.create(..., extra_headers={"api-key": key, "ai-gateway-version": "v2"})
#
# The OpenAI SDK appends /chat/completions to the base_url, so the full URL
# becomes: https://gateway.ai.yourcompany.com/chat/{model}/chat/completions
#
# AGENT_CLIENT_TYPE=gateway
# AI_GATEWAY_URL=https://gateway.ai.yourcompany.com
# AI_GATEWAY_TOKEN=<your-api-key>
#
# --- claude-sonnet-4 (recommended) ---
# AI_GATEWAY_MODEL=claude-sonnet-4
# AI_GATEWAY_COMPLETIONS_PATH=/chat/{model}/chat/completions
# AI_GATEWAY_AUTH_HEADER=api-key
# AI_GATEWAY_EXTRA_HEADERS=ai-gateway-version:v2
#
# --- gpt-4o / gpt-4o-mini / gpt-5-nano ---
# AI_GATEWAY_MODEL=gpt-4o
# AI_GATEWAY_COMPLETIONS_PATH=/chat/{model}/chat/completions
# AI_GATEWAY_AUTH_HEADER=api-key
# AI_GATEWAY_EXTRA_HEADERS=ai-gateway-version:v2
#
# NOTE: gpt-5 and gpt-4.1 use the Responses API (/responses) — NOT supported.
#       Use claude-sonnet-4, gpt-4o, gpt-4o-mini, or gpt-5-nano instead.
#
# Token limit tip: if the gateway enforces per-request token limits:
# AGENT_COMPACT_CONTEXT=true

# ── Paths (override for Docker / AKS deployments) ───────────────────────────
DATA_DIR=data/pipelines
OUTPUT_DIR=output
STATE_FILE=data/state/migration_state.json
CATALOG_DIR=catalog/stages
PROMPTS_DIR=agent/prompts

# ── Agent settings ───────────────────────────────────────────────────────────
AGENT_MAX_TOKENS=8096
AGENT_CONCURRENCY=3
AGENT_COMPACT_CONTEXT=false

# ── Review portal ────────────────────────────────────────────────────────────
REVIEW_HOST=0.0.0.0
REVIEW_PORT=8000
