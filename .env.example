# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Paths (override for container deployments)
DATA_DIR=data/pipelines
OUTPUT_DIR=output
STATE_FILE=data/state/migration_state.json
CATALOG_DIR=catalog/stages
PROMPTS_DIR=agent/prompts

# Agent settings
AGENT_MAX_TOKENS=8096
AGENT_CONCURRENCY=3

# Review portal
REVIEW_HOST=0.0.0.0
REVIEW_PORT=8000
