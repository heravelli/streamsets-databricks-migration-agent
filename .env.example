# ── Client selection ────────────────────────────────────────────────────────
# "anthropic" = call Anthropic API directly (local dev)
# "openai"    = call OpenAI API directly with your OPENAI_API_KEY
# "gateway"   = route through your enterprise AI gateway (required at work)
AGENT_CLIENT_TYPE=anthropic

# ── Option A: Direct Anthropic (local dev) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Option B: OpenAI (if you have an OpenAI API key) ─────────────────────────
# AGENT_CLIENT_TYPE=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o        # gpt-4o recommended — strong tool-use support

# ── Option C: Enterprise AI Gateway (required at work) ───────────────────────
# AGENT_CLIENT_TYPE=gateway
# AI_GATEWAY_TOKEN=<token-from-gateway-team>
#
# --- Route: claude-sonnet-4 via Azure AI Foundry gateway ---
# Path pattern:  /v1/openai/deployments/{model}/chat/completions
# AI_GATEWAY_URL=https://gateway.ai.yourcompany.com
# AI_GATEWAY_MODEL=claude-sonnet-4
# AI_GATEWAY_COMPLETIONS_PATH=/v1/openai/deployments/{model}/chat/completions
#
# --- Route: gpt-4o / gpt-4o-mini / gpt-5-nano via the same gateway ---
# Path pattern:  /openai/deployments/{model}/chat/completions
# AI_GATEWAY_URL=https://gateway.ai.yourcompany.com
# AI_GATEWAY_MODEL=gpt-4o
# AI_GATEWAY_COMPLETIONS_PATH=/openai/deployments/{model}/chat/completions
#
# --- Route: gemini-2.5-pro via the same gateway ---
# AI_GATEWAY_URL=https://gateway.ai.yourcompany.com
# AI_GATEWAY_MODEL=gemini-2.5-pro
# AI_GATEWAY_COMPLETIONS_PATH=/openai/deployments/{model}/chat/completions
#
# NOTE: gpt-5 and gpt-4.1 use the OpenAI Responses API (/responses endpoint)
#       which is NOT compatible with this client — use claude, gpt-4o, or gpt-4o-mini instead.
#
# When {model} appears in the path it is substituted at startup and the
# "model" field is omitted from the request body (some gateways reject it).
#
# If your gateway enforces per-request token limits, enable compact mode:
# AGENT_COMPACT_CONTEXT=true

# ── Paths (override for Docker / AKS deployments) ───────────────────────────
DATA_DIR=data/pipelines
OUTPUT_DIR=output
STATE_FILE=data/state/migration_state.json
CATALOG_DIR=catalog/stages
PROMPTS_DIR=agent/prompts

# ── Agent settings ───────────────────────────────────────────────────────────
AGENT_MAX_TOKENS=8096
AGENT_CONCURRENCY=3
AGENT_COMPACT_CONTEXT=false

# ── Review portal ────────────────────────────────────────────────────────────
REVIEW_HOST=0.0.0.0
REVIEW_PORT=8000
